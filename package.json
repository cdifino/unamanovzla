{
  "name": "mapa-ayuda",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mapa interactivo de coordinacion de ayuda humanitaria para Miranda, Distrito Capital y La Guaira (Vargas).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "node scripts/e2e.mjs",
    "gen:seed": "node scripts/gen-seed.mjs",
    "gen:geojson": "mapshaper src/data/parroquias.geojson -simplify 6% keep-shapes -clean -o public/parroquias.geojson format=geojson precision=0.00001"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "mapshaper": "^0.7.33",
    "puppeteer-core": "^20.9.0",
    "vite": "^4.5.3",
    "vitest": "^3.2.6"
  }
}
